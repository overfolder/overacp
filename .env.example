# Shared HS256 signing key for over/ACP JWTs.
# Required. No default — the server refuses to start without it.
# Generate with: openssl rand -hex 32
OVERACP_JWT_SIGNING_KEY=

# JWT issuer string. Must match what mints the tokens.
OVERACP_JWT_ISSUER=overacp

# LLM OpenRouter Key
LLM_API_KEY=sk_test_bbbb
# LLM_API_URL=https://openrouter.ai/api/v1
OVERFOLDER_MODEL=minimax/minimax-m2.7
