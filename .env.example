# Shared HS256 signing key for over/ACP session JWTs.
# Required. No default — the server refuses to start without it.
# Generate with: openssl rand -hex 32
OVERACP_JWT_SIGNING_KEY=

# JWT issuer string. Must match what mints the tokens.
OVERACP_JWT_ISSUER=overacp

# Path to an htpasswd(5) file with credentials for control-plane
# endpoints (/compute/*, admin /agents). Bcrypt only — generate with:
#   htpasswd -B -c /etc/overacp/creds alice
# If unset, control-plane endpoints return 503.
OVERACP_BASIC_AUTH_FILE=

# Default user UUID attributed to control-plane writes made via HTTP
# Basic auth (which carries no user identity). Generate with: uuidgen
OVERACP_DEFAULT_USER_ID=
